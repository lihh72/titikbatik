# Server-side address of the FastAPI backend. Do not add NEXT_PUBLIC_ here.
INTERNAL_API_URL=http://127.0.0.1:8000

# Administrator account for the private Next.js area.
ADMIN_EMAIL=admin@titikbatik.local
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_TOKEN=replace-with-a-long-random-session-token

# Must match ADMIN_API_KEY in ../automation/.env. This value remains server-side.
ADMIN_API_KEY=replace-with-the-automation-admin-key

# Meta Model API key. Server-side only, never expose with NEXT_PUBLIC_.
MODEL_API_KEY=replace-with-your-meta-model-api-key
MODEL_API_BASE_URL=https://api.meta.ai/v1
MODEL_API_MODEL=muse-spark-1.1
